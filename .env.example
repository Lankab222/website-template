# Build Adapter
# Options: cloudflare, vercel, netlify
# Default: cloudflare
ADAPTER=cloudflare

# Site URL
# The public URL of the application (e.g., used for sitemap generation, canonical URLs)
# Default: https://cooper.gladtek.com
SITE_URL=https://taifalemar.site/ar/
# Analytics
# Set to true to bypass cookie consent and always load analytics
ANALYTICS_ALWAYS_LOAD=false

# Google Analytics
GA_ID=G-3WY4E8G9SH
GA_ENABLED=true

# Rybbit Analytics
RYBBIT_ID=
RYBBIT_SRC=https://rybbit.example.com/api/script.js
RYBBIT_ENABLED=false

# Umami Analytics
UMAMI_ID=
UMAMI_SRC=https://analytics.umami.is/script.js
UMAMI_ENABLED=false
